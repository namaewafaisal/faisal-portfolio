# ============================================================
# Portfolio Environment Variables
# ============================================================
# Copy this file to .env.local for local dev.
# NEVER commit .env.local to git.
# ============================================================

# Optional: GitHub Personal Access Token
# Needed for:
#   - Fetching PINNED repositories (GraphQL)
#   - GitHub contribution graph
#   - Higher rate limits (60 → 5000 req/hour)
#
# How to create one:
#   https://github.com/settings/tokens
#   Scopes needed: public_repo, read:user
#
GITHUB_TOKEN=

# Port for the backend API server (default: 3001)
PORT=3001
